{
  "name": "citrix-sync-clipboard",
  "version": "1.0.0",
  "description": "Clipboard bridge for Citrix sessions using a shared text file.",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "cli:copy": "node copy.js",
    "cli:paste": "node paste.js",
    "dist": "electron-builder",
    "dist:dir": "electron-builder --dir",
    "dist:win": "electron-builder --win nsis",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "clipboardy": "^3.0.0",
    "readline": "^1.3.0"
  },
  "devDependencies": {
    "electron": "^35.0.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.yanyoo.citrix-sync-clipboard",
    "productName": "citrix-sync-clipboard",
    "asar": true,
    "files": [
      "electron/**/*",
      "lib/**/*",
      "*.js",
      "*.json",
      "*.md",
      "*.bat"
    ]
  }
}
